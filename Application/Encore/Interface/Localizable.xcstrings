    "PREFERENCES_TAB_GENERAL_ENABLE_LOGGING_DESCRIPTION" : {
      "extractionState" : "manual",
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Logs werden lokal gespeichert. Sie helfen mir, Fehler zu beheben, wenn du einen Bericht sendest. Deaktiviere die Funktion, wenn du sie nicht brauchst."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Logs are stored locally. They help me fix bugs when you submit a report. Disable it if you don’t need it."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les logs sont stockés localement. Ils m'aident à corriger les bugs lorsque tu soumets un rapport. Désactive-les si tu n'en as pas besoin."
          }
        },
        "lb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Logs gi lokal gespäichert. Si hëllefe mer, Feeler ze behiewen, wann s de e Rapport schécks. Desaktivéier d'Funktioun, wann s de se net brauchs."
          }
        }
      }
    },
